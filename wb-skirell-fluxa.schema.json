						"inputAttributes": {
							"placeholder": "setting_name_cover_case"
						}
					},
					"propertyOrder": 3
				},
				"icon_open": {
					"title": "icon_open_name",
					"description": "icon_desc",
					"type": "string",
					"minLength": 1,
					"options": {
						"inputAttributes": {
							"placeholder": "icon_open_case"
						}
					},
					"propertyOrder": 4
				},
				"icon_close": {
					"title": "icon_close_name",
					"description": "icon_desc",
					"type": "string",
					"minLength": 1,
					"options": {
						"inputAttributes": {
							"placeholder": "icon_close_case"
						}
					},
					"propertyOrder": 5
				},
				"variant_type": {
					"title": "variant_type_name",
					"description": "variant_type_name_desc",
					"type": "string",
					"enum": [
						"cover_variant_slider",
						"cover_variant_buttons"
					],
					"options": {
						"enum_titles": [
							"cover_variant_slider_name",
							"cover_variant_buttons_name"
