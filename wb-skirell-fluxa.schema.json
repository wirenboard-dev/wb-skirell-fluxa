						"open_command_topic": {
							"title": "open_command_topic_name",
							"description": "open_command_topic_desc",
							"type": "string",
							"minLength": 1,
							"options": {
								"wb": {
									"data": "devices"
								}
							},
							"_format": "wb-autocomplete",
							"propertyOrder": 2
						},
						"close_command_topic": {
							"title": "close_command_topic_name",
							"description": "close_command_topic_desc",
							"type": "string",
							"minLength": 1,
							"options": {
								"wb": {
									"data": "devices"
								}
							},
							"_format": "wb-autocomplete",
							"propertyOrder": 3
						},
						"stop_command_topic": {
							"title": "stop_command_topic_name",
							"description": "stop_command_topic_desc",
							"type": "string",
							"minLength": 1,
							"options": {
								"wb": {
									"data": "devices"
								}
							},
							"_format": "wb-autocomplete",
							"propertyOrder": 4
						},
						"payload_open": {
							"title": "payload_open_name",
							"description": "payload_open_desc",
							"type": "string",
							"minLength": 1,
							"options": {
								"inputAttributes": {
									"placeholder": "payload_open_case"
								}
							},
							"propertyOrder": 5
						},
						"payload_close": {
							"title": "payload_close_name",
							"description": "payload_close_desc",
							"type": "string",
							"minLength": 1,
							"options": {
								"inputAttributes": {
									"placeholder": "payload_close_case"
								}
							},
							"propertyOrder": 6
						},
						"payload_stop": {
							"title": "payload_stop_name",
							"description": "payload_stop_desc",
							"type": "string",
							"minLength": 1,
							"options": {
								"inputAttributes": {
									"placeholder": "payload_stop_case"
								}
							},
							"propertyOrder": 7
						},
						"position_command_topic": {
							"title": "position_command_topic_name",
							"description": "position_command_topic_desc",
							"type": "string",
							"minLength": 1,
							"options": {
								"dependencies": {
									"type": ["cover_variant_slider"]
								},
								"wb": {
									"data": "devices"
								}
							},
							"_format": "wb-autocomplete",
							"propertyOrder": 8
						},
						"position_state_topic": {
							"title": "position_state_topic_name",
							"description": "position_state_topic_desc",
							"type": "string",
							"minLength": 1,
							"options": {
