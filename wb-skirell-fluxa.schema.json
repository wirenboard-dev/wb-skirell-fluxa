{
	"$schema": "http://json-schema.org/draft-04/schema#",
	"type": "object",
	"title": "config_title",

	"configFile": {
		"path": "/etc/wb-skirell-fluxa.conf",
		"toJSON": ["/usr/lib/cgi-bin/skirell-fluxa.py", "-load"],
		"fromJSON": ["/usr/lib/cgi-bin/skirell-fluxa.py", "-save"]
	},

	"properties": {
		"panels": {
			"type": "array",
			"items": {
				"headerTemplate": "panel_title",
				"title": "panel_element",
				"type": "object",
				"properties": {
					"crc": {
						"type": "string",
						"options": {"hidden": true}
					},
					"link": {
						"type": "string",
						"options": {"hidden": true}
					},
					"name": {
						"title": "panel_name_title",
						"type": "string",
						"options": {
							"inputAttributes": {
								"placeholder":  "panel_name_case"
							}
						},
						"propertyOrder": 1
					},
					"id": {
						"title": "panel_id_title",
						"type": "string",
						"pattern": "^[0-9A-Fa-f]{12}$",
						"options": {
							"patternmessage": "panel_id_pattern",
							"inputAttributes": {
								"placeholder":  "XXXXXXXXXXXX"
							}
						},
						"propertyOrder": 2
					},
					"screens": {
						"title": "screens_title",
						"type": "array",
						"items": {
							"title": "screens_element",
							"type": "object",
							"properties": {
								"blocks": {
									"title": "blocks_element",
									"type": "array",
									"maxItems": 4,
									"items": {
										"title": "blocks_title",
										"type": "object",
										"oneOf": [
											{"$ref": "#/definitions/block_scene"},
											{"$ref": "#/definitions/block_light"},
											{"$ref": "#/definitions/block_cover"},
											{"$ref": "#/definitions/block_sensor"},
											{"$ref": "#/definitions/block_switch"}
										],
										"options": {
											"keep_oneof_values": false,
											"disable_collapse": true,
											"disable_edit_json": true,
											"disable_properties": true,
											"wb": {
												"disable_panel": true
											}
										},
										"_format": "wb-multiple"
									},
									"options": {
										"disable_collapse": true,
										"enable_array_copy": true,
										"disable_array_delete_last_row": true
									},
									"_format": "tabs",
									"propertyOrder": 2
								}
							},
							"options": {
								"disable_edit_json": true,
								"disable_properties": true,
								"wb": {
									"disable_title": true
								}
							},
							"_format": "wb-multiple"
						},
						"options": {
							"enable_array_copy": true,
							"disable_collapse": true
						},
						"_format": "tabs-top",
						"propertyOrder": 3
					}
				},
				"options": {
					"disable_edit_json": true,
					"disable_properties": true,
					"collapsed": true
				},
				"required": ["id"],
				"_format": "wb-object"
			},
			"options": {
				"disable_array_delete_last_row": true,
				"disable_array_delete_all_rows": true,
				"enable_array_copy": true,
                "wb": {
					"disable_title": true,
                    "disable_panel": true
                }
			},
			"_format": "wb-multiple"
		}
	},

	"definitions": {
		"color_picker": {
			"type": "string",
			"enum": [
				"color_red",
				"color_pink",
				"color_orange",
				"color_yellow",
				"color_mint",
				"color_green",
				"color_cyan",
				"color_blue",
				"color_dark_blue",
				"color_indigo",
				"color_purple",
				"color_brown",
				"color_white"
			],
			"options": {
				"enum_titles": [
					"Red",
					"Pink",
					"Orange",
					"Yellow",
					"Mint",
					"Green",
					"Cyan",
					"Blue",
					"Dark blue",
					"Indigo",
					"Purple",
					"Brown",
					"White"
				]
			}
		},

		"block_scene": {
			"title": "block_scene_name",
			"type": "object",
			"properties": {
				"type": {
					"type": "string",
					"enum": ["scene"],
					"options": {"hidden": true}
				},
				"param_1": {
					"title": "param_1_name",
					"description": "param_1_desc",
					"type": "string",
					"default": "",
					"options": {
						"show_opt_in": true,
						"inputAttributes": {
							"placeholder": "params_scene_case"
						}
					},
					"propertyOrder": 1
				},
				"param_2": {
					"title": "param_2_name",
					"description": "param_2_desc",
					"type": "string",
					"options": {
						"show_opt_in": true,
						"inputAttributes": {
							"placeholder": "params_scene_case"
						}
					},
					"propertyOrder": 2
				},
				"param_3": {
					"title": "param_3_name",
					"description": "param_3_desc",
					"type": "string",
					"options": {
						"show_opt_in": true,
						"inputAttributes": {
							"placeholder": "params_scene_case"
						}
					},
					"propertyOrder": 3
				},
				"icon": {
					"title": "icon_name",
					"description": "icon_desc",
					"type": "string",
					"minLength": 1,
					"options": {
						"inputAttributes": {
							"placeholder": "icon_scene_case"
						}
					},
					"propertyOrder": 4
				},
				"command_topic": {
					"title": "command_topic_name",
					"description": "command_topic_desc",
					"type": "string",
					"minLength": 1,
					"options": {
						"wb": {
							"data": "devices"
						}
					},
					"_format": "wb-autocomplete",
					"propertyOrder": 5
				},
				"payload": {
					"title": "payload_name",
					"description": "payload_desc",
					"type": "string",
					"minLength": 1,
					"default": "1",
					"options": {
						"inputAttributes": {
							"placeholder": "payload_case"
						}
					},
					"propertyOrder": 6
				}
			},
			"required": ["type", "icon", "command_topic", "payload"]
		},

		"block_light": {
			"title": "block_light_name",
			"type": "object",
			"id": "light",
			"properties": {
				"type": {
					"type": "string",
					"enum": ["light"],
					"options": {"hidden": true}
				},
				"param_1": {
					"title": "param_1_name",
					"description": "param_1_desc",
					"type": "string",
					"options": {
						"show_opt_in": true,
						"inputAttributes": {
							"placeholder": "params_light_case"
						}
					},
					"propertyOrder": 1
				},
				"param_2": {
					"title": "param_2_name",
					"description": "param_2_desc",
					"type": "string",
					"options": {
						"show_opt_in": true,
						"inputAttributes": {
							"placeholder": "params_light_case"
						}
					},
					"propertyOrder": 2
				},
				"setting_name": {
					"title": "setting_name",
					"description": "setting_name_desc",
					"type": "string",
					"minLength": 1,
					"options": {
						"inputAttributes": {
							"placeholder": "setting_name_light_case"
						}
					},
					"propertyOrder": 3
				},
				"icon": {
					"title": "icon_name",
					"description": "icon_desc",
					"type": "string",
					"minLength": 1,
					"options": {
						"inputAttributes": {
							"placeholder": "icon_light_case"
						}
					},
					"propertyOrder": 4
				},
				"variant_type": {
                    "title": "variant_type_name",
					"description": "variant_type_name_desc",
					"type": "string",
					"enum": [
						"light_variant_OnOff",
						"light_variant_dimmer",
						"light_variant_color",
						"light_variant_temperature"
					],
					"options": {
						"enum_titles": [
							"light_variant_OnOff_name",
							"light_variant_dimmer_name",
							"light_variant_color_name",
							"light_variant_temperature_name"
						]
					},
					"default": "light_variant_OnOff",
                    "propertyOrder": 5
                },
				"variant": {
					"type": "object",
					"properties": {
						"type": {
							"type": "string",
							"watch": {"value": "light.variant_type"},
							"template": "{{ value }}",
							"options": {"hidden": true}
						},
						"OnOff_command_topic": {
							"title": "OnOff_command_topic_name",
							"description": "OnOff_command_topic_desc",
							"type": "string",
							"minLength": 1,
							"options": {
								"wb": {
									"data": "devices"
								}
							},
							"_format": "wb-autocomplete",
							"propertyOrder": 1
						},
						"OnOff_state_topic": {
							"title": "OnOff_state_topic_name",
							"description": "OnOff_state_topic_desc",
							"type": "string",
							"minLength": 1,
							"options": {
								"wb": {
									"data": "devices"
								}
							},
							"_format": "wb-autocomplete",
							"propertyOrder": 2
						},
						"payload_on": {
							"title": "payload_on_name",
							"description": "payload_on_desc",
							"type": "string",
							"minLength": 1,
							"default": "1",
							"options": {
								"inputAttributes": {
									"placeholder": "payload_on_case"
								}
							},
							"propertyOrder": 3
						},
						"payload_off": {
							"title": "payload_off_name",
							"description": "payload_off_desc",
							"type": "string",
							"minLength": 1,
							"default": "0",
							"options": {
								"inputAttributes": {
									"placeholder": "payload_off_case"
								}
							},
							"propertyOrder": 4
						},
						"brightness_command_topic": {
							"title": "brightness_command_topic_name",
							"description": "brightness_command_topic_desc",
							"type": "string",
							"minLength": 1,
							"options": {
								"dependencies": {
									"type": ["light_variant_dimmer", "light_variant_color", "light_variant_temperature"]
								},
								"wb": {
									"data": "devices"
								}
							},
							"_format": "wb-autocomplete",
							"propertyOrder": 5
						},
						"brightness_state_topic": {
							"title": "brightness_state_topic_name",
							"description": "brightness_state_topic_desc",
							"type": "string",
							"minLength": 1,
							"options": {
								"dependencies": {
									"type": ["light_variant_dimmer", "light_variant_color", "light_variant_temperature"]
								},
								"wb": {
									"data": "devices"
								}
							},
							"_format": "wb-autocomplete",
							"propertyOrder": 6
						},
						"brightness_scale": {
							"title": "brightness_scale_name",
							"description": "brightness_scale_desc",
							"type": "integer",
							"default": "100",
							"options": {
								"dependencies": {
									"type": ["light_variant_dimmer", "light_variant_color", "light_variant_temperature"]
								},
								"inputAttributes": {
									"placeholder": "brightness_scale_case"
								}
							},
							"propertyOrder": 7
						},
						"color_command_topic": {
							"title": "color_command_topic_name",
							"description": "color_command_topic_desc",
							"type": "string",
							"minLength": 1,
							"options": {
								"dependencies": {
									"type": ["light_variant_color"]
								},
								"wb": {
									"data": "devices"
								}
							},
							"_format": "wb-autocomplete",
							"propertyOrder": 8
						},
						"color_type": {
							"title": "color_type_name",
							"description": "color_type_desc",
							"type": "string",
							"enum": ["rgb", "hex", "hsv", "hsl"],
							"options": {
								"enum_titles": ["RGB", "HEX", "HSV", "HSL"],
								"dependencies": {
									"type": ["light_variant_color"]
								}
							},
							"propertyOrder": 9
						},
						"temp_command_topic": {
							"title": "temp_command_topic_name",
							"description": "temp_command_topic_desc",
							"type": "string",
							"minLength": 1,
							"options": {
								"dependencies": {
									"type": ["light_variant_temperature"]
								},
								"wb": {
									"data": "devices"
								}
							},
							"_format": "wb-autocomplete",
							"propertyOrder": 10
						},
						"temp_state_topic": {
							"title": "temp_state_topic_name",
							"description": "temp_state_topic_desc",
							"type": "string",
							"minLength": 1,
							"options": {
								"dependencies": {
									"type": ["light_variant_temperature"]
								},
								"wb": {
									"data": "devices"
								}
							},
							"_format": "wb-autocomplete",
							"propertyOrder": 11
						},
						"min_temp": {
							"title": "min_temp_name",
							"description": "min_temp_desc",
							"type": "integer",
							"default": "0",
							"options": {
								"dependencies": {
									"type": ["light_variant_temperature"]
								},
								"inputAttributes": {
									"placeholder": "min_temp_case"
								}
							},
							"propertyOrder": 12
						},
						"max_temp": {
							"title": "max_temp_name",
							"description": "max_temp_desc",
							"type": "integer",
							"default": "100",		
							"options": {
								"dependencies": {
									"type": ["light_variant_temperature"]
								},
								"inputAttributes": {
									"placeholder": "max_temp_case"
								}
							},
							"propertyOrder": 13
						},
						"temp_measure": {
							"title": "temp_measure_name",
							"description": "temp_measure_desc",
							"type": "string",
							"minLength": 1,
							"default": "%",
							"options": {
								"dependencies": {
									"type": ["light_variant_temperature"]
								},
								"inputAttributes": {
									"placeholder": "temp_measure_case"
								}
							},
							"propertyOrder": 14
						}
					},
					"options": {
						"wb": {
							"disable_title": true,
							"disable_panel": true
						}
					},
					"allOf": [
						{
							"if": {
								"properties": {
									"state": {"const": "light_variant_OnOff"}
								}
							},
							"then": {
								"required": [
									"OnOff_command_topic",
									"OnOff_state_topic",
									"payload_on",
									"payload_off"
								]
							}
						},
						{
							"if": {
								"properties": {
									"state": {"const": "light_variant_dimmer"}
								}
							},
							"then": {
								"required": [
									"OnOff_command_topic",
									"OnOff_state_topic",
									"payload_on",
									"payload_off",
									"brightness_command_topic",
									"brightness_state_topic",
									"brightness_scale"
								]
							}
						},
						{
							"if": {
								"properties": {
									"state": {"const": "light_variant_color"}
								}
							},
							"then": {
								"required": [
									"OnOff_command_topic",
									"OnOff_state_topic",
									"payload_on",
									"payload_off",
									"brightness_command_topic",
									"brightness_state_topic",
									"brightness_scale",
									"color_command_topic",
									"color_type"
								]
							}
						},
						{
							"if": {
								"properties": {
									"state": {"const": "light_variant_temperature"}
								}
							},
							"then": {
								"required": [
									"OnOff_command_topic",
									"OnOff_state_topic",
									"payload_on",
									"payload_off",
									"brightness_command_topic",
									"brightness_state_topic",
									"brightness_scale",
									"temp_command_topic",
									"temp_state_topic",
									"min_temp",
									"max_temp",
									"temp_measure"
								]
							}
						}
					],
					"propertyOrder": 6
				}
			},
			"required": ["type", "setting_name", "icon", "variant_type"]
		},

		"block_cover": {
			"title": "block_cover_name",
			"type": "object",
			"id": "cover",
			"properties": {
				"type": {
